{
    "tasks": {
        "dev": "DENO_ENV=development deno run -A --env-file=.env --watch ./src/server.ts",
        "kysely": "deno run -A './node_modules/kysely-ctl/dist/bin.js'",
        "format": "deno fmt ./src",
        "lint": "deno lint ./src",
        "gen-types": "bash ./bin/gen-db-types.sh",
        "add-user": "deno run --allow-env --allow-net --env-file=.env ./bin/add-test-user.ts",
        "gen-route": "deno run --allow-read --allow-write ./bin/make-route.ts",
        "get-token": "deno run --allow-env --allow-net --env-file=.env ./bin/get-access-token.ts"
    },
    "imports": {
        "@std/cli": "jsr:@std/cli@^1.0.16",
        "@supabase/supabase-js": "jsr:@supabase/supabase-js@^2.49.4",
        "@types/express": "npm:@types/express@^5.0.1",
        "@types/pg": "npm:@types/pg@^8.11.12",
        "cors": "npm:cors@^2.8.5",
        "express": "npm:express@5.1.0",
        "express-rate-limit": "npm:express-rate-limit@^7.5.0",
        "helmet": "npm:helmet@^8.1.0",
        "kysely": "npm:kysely@^0.27.6",
        "kysely-codegen": "npm:kysely-codegen@^0.18.3",
        "kysely-ctl": "npm:kysely-ctl@^0.12.1",
        "morgan": "npm:morgan@^1.10.0",
        "pg": "npm:pg@^8.14.1",
        "zod": "npm:zod@^3.24.2"
    },
    "fmt": {
        "indentWidth": 4,
        "singleQuote": true,
        "semiColons": true,
        "lineWidth": 80
    },
    "lint": {
        "include": ["src/"],
        "rules": {
            "tags": ["recommended"],
            "exclude": ["no-unused-vars"]
        }
    },
    "nodeModulesDir": "auto"
}
